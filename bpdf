#!/usr/bin/env sh

set -e

err() {
  printf "Error: %s\n" "$*" >&2
}

if [ -z "$1" ]; then
  echo "Enter a file name." >&2
  exit
fi

if ! head -c 4 "$1" | grep -q "%PDF"; then
  echo "$1 is not a PDF." >&2
  exit
fi

DATE=$(date +%s)

if [ ! -d "/tmp/bpdf" ]; then
  mkdir /tmp/bpdf
fi

mutool convert -o /tmp/bpdf/$DATE.html -F html "$1"

if [ -z "${VIEWER:-}" ]; then
  for v in links elinks lynx w3m firefox chromium; do
    if command -v "$v" >/dev/null 2>&1; then
      VIEWER=$v
      break
    fi
  done
fi

[ -n "${VIEWER:-}" ] || {
  err "No HTML viewer found (links, elinks, lynx, w3m, firefox, chromium). Set \$VIEWER."
  exit 1
}

"$VIEWER" "/tmp/bpdf/$DATE.html"
rm "/tmp/bpdf/$DATE.html" -f
